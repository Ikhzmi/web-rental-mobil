# ── Prisma / Postgres (dari dashboard Supabase: Project Settings > Database) ──
# Connection pooler (PgBouncer, port 6543) — dipakai runtime app.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Koneksi langsung (port 5432) — khusus `prisma migrate`.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres"

# ── Supabase (dari dashboard: Project Settings > API) ──
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# Anon key — aman dipakai untuk memverifikasi token di middleware.
SUPABASE_ANON_KEY="eyJ..."
# Service-role key — RAHASIA. Jangan pernah commit ke repo atau kirim ke frontend.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── App ──
PORT=3001
# Origin frontend yang diizinkan CORS, pisahkan dengan koma bila lebih dari satu.
FRONTEND_ORIGIN="http://localhost:5173"
NODE_ENV="development"
